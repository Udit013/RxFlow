# RxFlow API — production env (set these in the Render dashboard, NOT in the repo)
NODE_ENV=production
PORT=3001

# Neon pooled connection string (use the one ending in -pooler for serverless)
# postgresql://USER:PASS@ep-xxx-pooler.REGION.aws.neon.tech/rxflow?sslmode=require
DATABASE_URL=

# Generate each with: openssl rand -base64 48  (must be DIFFERENT values)
JWT_SECRET=
JWT_REFRESH_SECRET=

# Your Vercel frontend origin (comma-separated for multiple). Avoid "*" in prod.
CORS_ORIGIN=https://your-app.vercel.app

# File storage — Cloudflare R2 (S3-compatible, 10GB free)
STORAGE_PROVIDER=s3
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=auto
AWS_BUCKET=rxflow-uploads
AWS_ENDPOINT=https://ACCOUNT_ID.r2.cloudflarestorage.com

# Email (password reset / OTP) — Resend free tier
RESEND_API_KEY=
