# ─────────────────────────────────────────────────────────────────────────────
# RxFlow Environment Variables
# Copy this to .env in apps/api/ and fill in your values
# ─────────────────────────────────────────────────────────────────────────────

# ── App ───────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001

# ── Database ──────────────────────────────────────────────────────────────────
# Local (Docker Compose)
#DATABASE_URL=postgresql://rxflow:rxflow_dev_secret@localhost:5432/rxflow?schema=public

# Production ( Neon)
DATABASE_URL=postgresql://neondb_owner:npg_xyjke6shf3TQ@ep-winter-recipe-ai80mjpq-pooler.c-4.us-east-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require
# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
JWT_SECRET=your-super-secret-jwt-key-min-32-chars-here
JWT_REFRESH_SECRET=your-refresh-secret-different-from-access

# ── CORS ─────────────────────────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:3000

# ── Search (Meilisearch) ──────────────────────────────────────────────────────
MEILISEARCH_HOST=http://localhost:7700
MEILISEARCH_KEY=rxflow_meili_key

# ── Redis (optional, for advanced caching) ───────────────────────────────────
# REDIS_URL=redis://localhost:6379

# ── File Storage ─────────────────────────────────────────────────────────────
STORAGE_PROVIDER=local
# For local storage:
STORAGE_BASE_URL=http://localhost:3001/uploads

# For S3 / MinIO:
# STORAGE_PROVIDER=s3
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=ap-south-1
# AWS_BUCKET=rxflow-uploads

# ── AI/OCR (for prescription scanning) ───────────────────────────────────────
# OpenAI (GPT-4 Vision for prescription OCR)
# OPENAI_API_KEY=sk-...

# Google Vision API (alternative OCR)
# GOOGLE_VISION_API_KEY=

# ── WhatsApp (for order notifications) ───────────────────────────────────────
# Interakt / Wati / 360dialog API key
# WHATSAPP_API_KEY=

# ── GST E-invoicing (optional, production only) ───────────────────────────────
# EINVOICE_API_URL=https://einv-apisandbox.nic.in
# EINVOICE_API_KEY=

# ── Frontend ──────────────────────────────────────────────────────────────────
# apps/web/.env.local
NEXT_PUBLIC_API_URL=http://localhost:3001/api/v1
